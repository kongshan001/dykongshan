{
  "role": "qa",
  "required_fields": ["score", "improvements", "risks", "missing_tests", "test_coverage"],
  "schema": {
    "score": "number (0-10)",
    "improvements": "array of strings (改善建议)",
    "risks": "array of strings (风险点)",
    "missing_tests": "array of objects {type: unit|integration, description, reason}",
    "test_coverage": {
      "line_rate": "number (0-1)",
      "branch_rate": "number (0-1)",
      "pass_rate": "number (0-1)"
    },
    "test_results": {
      "total": "number",
      "passed": "number",
      "failed": "number"
    }
  }
}
