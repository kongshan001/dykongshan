{
  "role": "designer",
  "required_fields": ["score", "improvements", "risks", "visual_score", "interaction_score", "consistency_score"],
  "schema": {
    "score": "number (0-10)",
    "improvements": "array of strings (改善建议)",
    "risks": "array of strings (风险点)",
    "visual_score": "number (0-10) 美观度评分",
    "interaction_score": "number (0-10) 交互流畅度评分",
    "consistency_score": "number (0-10) 一致性评分",
    "note": "对于非UI任务，visual_score/interaction_score/consistency_score 默认给 10，总 score 给 10，表示通过"
  }
}
