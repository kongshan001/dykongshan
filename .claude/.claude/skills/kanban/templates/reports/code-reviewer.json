{
  "role": "code_reviewer",
  "required_fields": ["average_score", "score", "improvements", "risks", "architecture_issues", "code_style_violations"],
  "schema": {
    "average_score": "number (0-10) — 加权平均评分（优先读取，各维度加权平均。evaluator_record_score 优先读取此字段，不存在时 fallback 到 score）",
    "score": "number (0-10) — 综合评分（向后兼容，当 average_score 不存在时使用）",
    "improvements": "array of strings (改善建议)",
    "risks": "array of strings (风险点)",
    "architecture_issues": "array of objects {issue, severity, location}",
    "code_style_violations": "array of objects {rule, file, line}",
    "quality_metrics": {
      "lint_pass_rate": "number (0-1)",
      "test_coverage": "number (0-1)",
      "build_pass": "boolean",
      "structure_compliance": "boolean"
    }
  }
}
