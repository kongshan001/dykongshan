{
  "role": "pm",
  "required_fields": ["average_score", "score", "improvements", "risks", "extended_requirements", "requirement_coverage"],
  "schema": {
    "average_score": "number (0-10) — 加权平均评分（优先读取，各维度加权平均。evaluator_record_score 优先读取此字段，不存在时 fallback 到 score）",
    "score": "number (0-10) — 综合评分（向后兼容，当 average_score 不存在时使用）",
    "improvements": "array of strings (改善建议)",
    "risks": "array of strings (风险点)",
    "extended_requirements": "array of objects {requirement, priority, rationale}",
    "requirement_coverage": {
      "total_points": "number",
      "covered_points": "number",
      "coverage_rate": "number (0-1)",
      "uncovered": "array of strings"
    }
  }
}
